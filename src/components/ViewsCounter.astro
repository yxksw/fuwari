---
import { Icon } from "astro-icon/components";

type Props = {
	pathname: string;
	suffix?: string;
	id?: string;
};

const { pathname, suffix = "次" } = Astro.props;
const id =
	Astro.props.id ?? `page-views-${pathname.replace(/[^a-zA-Z0-9]+/g, "-")}`;
---

<div class="flex items-center" id={`${id}-wrapper`} style="display: none;">
	<div class="meta-icon">
		<Icon name="material-symbols:visibility-outline-rounded" class="text-xl" />
	</div>
	<span class="text-50 text-sm font-medium" id={id}></span>
</div>

<script define:vars={{ pathname, id, suffix }}>
	async function loadViews() {
		const wrapper = document.getElementById(`${id}-wrapper`);
		const el = document.getElementById(id);
		if (!el || !wrapper) return;
		
		try {
			const res = await fetch(
				`https://t.2x.nz/share?pathname=${encodeURIComponent(pathname)}`,
			);
			if (!res.ok) return;
			
			const data = await res.json();
			const views = data?.views || 0;
			
			el.textContent = `${views} ${suffix}`;
			wrapper.style.display = 'flex';
		} catch {
			// 请求失败，保持隐藏
		}
	}

	if (document.readyState === "loading")
		document.addEventListener("DOMContentLoaded", loadViews);
	else loadViews();
</script>

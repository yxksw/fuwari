---
import path from "node:path";
interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	loading?: "eager" | "lazy";
	objectFit?: "cover" | "contain";
}
import { Image } from "astro:assets";
import { siteConfig } from "../../config";
import { url } from "../../utils/url-utils";

const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	loading = "lazy",
	objectFit = "cover",
} = Astro.props;
const className = Astro.props.class;

const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:") ||
	src === "random" ||
	src.includes("random")
);
const isPublic = src.startsWith("/");

// TODO temporary workaround for images dynamic import
// https://github.com/withastro/astro/issues/3373
// biome-ignore lint/suspicious/noImplicitAnyLet: <explanation>
let img;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>(
		"../../**/*.{png,jpg,jpeg,webp,avif,gif,svg}",
		{
			import: "default",
		},
	);
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	}
	img = await file();
}

const imageClass = `w-full h-full object-${objectFit}`;
const imageStyle = `object-position: ${position}`;
const fetchPriority = loading === "eager" ? "high" : "low";
---
<div id={id} class:list={[className, 'overflow-hidden relative image-wrapper']} style={`--theme-hue: ${siteConfig.themeColor.hue}`}>
    {isLocal && img && <Image src={img} alt={alt || ""} class={`${imageClass} image-content ${src === 'random' || src.includes('random') ? 'post-cover-random' : ''}`} style={imageStyle} loading={loading} fetchpriority={fetchPriority} decoding="async" />}
    {!isLocal && (
        <img src={src === 'random' ? 'https://p.2x.nz/ri/h/1.webp' : (isPublic ? url(src) : src)} alt={alt || ""} class={`${imageClass} image-content ${src === 'random' || src.includes('random') ? 'post-cover-random' : ''}`} style={imageStyle} loading={loading} fetchpriority={fetchPriority} decoding="async" />
    )}
</div>

<style>
    .image-content {
        transition: none;
    }
    .image-wrapper {
        min-height: 0;
    }
    .image-content[loading="lazy"] {
        content-visibility: auto;
    }
</style>

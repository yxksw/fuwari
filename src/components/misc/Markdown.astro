---
interface Props {
	class: string;
}
const className = Astro.props.class;
---
<div data-pagefind-body class=`prose prose-invert prose-base !max-w-none custom-md break-words ${className}`>
    <!--<div class="prose prose-invert max-w-none custom-md">-->
    <!--<div class="max-w-none custom-md">-->
    <slot/>
</div>

<script>
let mermaidLoader: Promise<any> | null = null;

const loadMermaid = async () => {
    if (!mermaidLoader) {
        mermaidLoader = import("mermaid").then((mod) => {
            const mermaid = mod.default;
            mermaid.initialize({
                startOnLoad: false,
                securityLevel: "loose",
                theme: "base",
                darkMode: true,
                themeVariables: {
                    textColor: "#e5e7eb",
                    lineColor: "#e5e7eb",
                    primaryColor: "#1f2937",
                    primaryTextColor: "#f9fafb",
                    primaryBorderColor: "#9ca3af",
                    secondaryColor: "#111827",
                    secondaryBorderColor: "#9ca3af",
                    tertiaryColor: "#0f172a",
                    edgeLabelBackground: "#0b1220",
                    clusterBkg: "#111827",
                    clusterBorder: "#9ca3af",
                },
            });
            return mermaid;
        });
    }

    return mermaidLoader;
};

const transformMermaidBlocks = () => {
    console.log("[Mermaid Debug] 开始转换 mermaid 代码块");
    const allPres = document.querySelectorAll(".custom-md pre");
    console.log("[Mermaid Debug] 找到的 pre 元素数量:", allPres.length);
    
    allPres.forEach((pre, index) => {
        console.log(`[Mermaid Debug] 处理第 ${index + 1} 个 pre 元素`);
        
        if ((pre as HTMLElement).dataset.mermaidProcessed === "true") {
            console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 已处理过，跳过`);
            return;
        }
        
        const code = pre.querySelector("code");
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的 code 元素:`, code);
        
        const langSources = [
            code?.getAttribute("data-language"),
            pre.getAttribute("data-language"),
            pre.closest("[data-language]")?.getAttribute("data-language"),
        ];
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的语言来源:`, langSources);
        
        const className = `${pre.className || ""} ${code?.className || ""}`;
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的 className:`, className);
        
        const lang = (langSources.find(Boolean) || "").toLowerCase();
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的语言:`, lang);
        
        const isMermaid = className.includes("language-mermaid") || lang === "mermaid";
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 是否为 mermaid:`, isMermaid);
        
        if (!isMermaid) return;

        // 使用 innerText 而不是 textContent 来正确处理 HTML 实体
        const codeElements = code ? Array.from(code.querySelectorAll(".code:not(summary *)")) : [];
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的 .code 元素数量:`, codeElements.length);
        
        const sourceByLines = code
            ? codeElements
                .map((el) => (el as HTMLElement).innerText || el.textContent)
                .map((text) => (text === "\n" ? "" : text))
                .join("\n")
                .trim()
            : "";
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的 sourceByLines:`, sourceByLines);
        
        const source = sourceByLines || (code as HTMLElement)?.innerText?.trim() || code?.textContent?.trim();
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的最终 source:`, source);
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的 source 长度:`, source?.length);
        
        if (!source) {
            console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的 source 为空，跳过`);
            return;
        }

        const container = document.createElement("div");
        container.className = "mermaid";
        container.textContent = source;
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 创建的 mermaid 容器:`, container);
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 的 mermaid 容器内容:`, container.textContent);
        
        (pre as HTMLElement).dataset.mermaidProcessed = "true";
        pre.replaceWith(container);
        console.log(`[Mermaid Debug] 第 ${index + 1} 个 pre 已替换为 mermaid 容器`);
    });
    
    console.log("[Mermaid Debug] mermaid 代码块转换完成");
};

const renderMermaidBlocks = async () => {
    console.log("[Mermaid Debug] 开始渲染 mermaid 图表");
    transformMermaidBlocks();
    
    const mermaidNodes = document.querySelectorAll(".custom-md .mermaid");
    console.log("[Mermaid Debug] 找到的 .mermaid 元素数量:", mermaidNodes.length);
    
    if (!mermaidNodes.length) {
        console.log("[Mermaid Debug] 没有找到 mermaid 元素，结束渲染");
        return;
    }
    
    console.log("[Mermaid Debug] 开始加载 mermaid 库");
    const mermaid = await loadMermaid();
    console.log("[Mermaid Debug] mermaid 库加载完成:", mermaid);
    
    try {
        console.log("[Mermaid Debug] 开始执行 mermaid.run()");
        await mermaid.run({
            nodes: Array.from(mermaidNodes),
        });
        console.log("[Mermaid Debug] mermaid.run() 执行成功");
    } catch (error) {
        console.error("[Mermaid Debug] mermaid.run() 执行失败:", error);
    }
};

const wrapMarkdownTables = () => {
    document.querySelectorAll(".custom-md table").forEach((table) => {
        const parent = table.parentElement;
        if (parent && parent.classList.contains("table-wrapper")) return;

        const wrapper = document.createElement("div");
        wrapper.className = "table-wrapper";
        table.parentNode?.insertBefore(wrapper, table);
        wrapper.appendChild(table);
    });
};

const initMarkdown = () => {
    wrapMarkdownTables();
    void renderMermaidBlocks();
};

// 初始加载
if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMarkdown);
} else {
    initMarkdown();
}

// SPA 导航后重新初始化
document.addEventListener("astro:page-load", initMarkdown);

document.addEventListener("click", function (e: MouseEvent) {
    const target = e.target as Element | null;
    if (target && target.classList.contains("copy-btn")) {
        const preEle = target.closest("pre");
        const codeEle = preEle?.querySelector("code");
        const code = Array.from(codeEle?.querySelectorAll(".code:not(summary *)") ?? [])
            .map(el => el.textContent)
            .map(t => t === "\n" ? "" : t)
            .join("\n");
        navigator.clipboard.writeText(code);

        const timeoutId = target.getAttribute("data-timeout-id");
        if (timeoutId) {
            clearTimeout(parseInt(timeoutId));
        }

      target.classList.add("success");

      // 使用 transitionend 事件替代 setTimeout
        target.addEventListener('transitionend', () => {
            target.classList.remove("success");
        }, { once: true });
        target.setAttribute("data-timeout-id", newTimeoutId.toString());
    }

    const spoiler = target?.closest(".spoiler");
    if (spoiler) {
        const isVisible = spoiler.classList.contains("visible");
        const isLink = target?.closest("a");
        const isCopyBtn = target?.closest(".copy-btn");
        
        if (!isVisible) {
            // Reveal
            spoiler.classList.add("visible");
            spoiler.setAttribute("title", "");
            e.preventDefault();
            e.stopPropagation();
        } 
        // If visible, do nothing. Let the event propagate to Fancybox or other handlers.
    }
}, true); // Use capture to prevent Fancybox from opening on first click
</script>

<style is:global>
    .spoiler {
        filter: blur(0.4rem);
        transition: filter 0.3s;
        cursor: pointer;
        user-select: none;
    }
    .spoiler:hover {
        opacity: 0.8;
    }
    .spoiler.visible {
        filter: none;
        user-select: auto;
        cursor: auto; /* Restore default cursor (or zoom-in for fancybox) */
        opacity: 1;
    }
</style>

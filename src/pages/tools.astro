---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

// 自动发现所有工具页面
const toolPages = await Astro.glob('./tools/**/*.astro');

// 过滤并提取工具页面信息
const tools = toolPages
	.filter(page => {
		return page.frontmatter?.toolMeta;
	})
	.map(page => {
		const meta = page.frontmatter.toolMeta;
		// 从文件路径提取路由路径
		const filePath = page.file?.split('/pages/')[1]?.replace('.astro', '') || '';
		const routePath = filePath.replace(/\/index$/, '');
		return {
			title: meta.title,
			desc: meta.description,
			href: `/${routePath}/`,
			icon: meta.icon,
			isCustom: meta.isCustomIcon,
			order: meta.order || 999,
		};
	})
	.sort((a, b) => a.order - b.order);
---

<MainGridLayout title="工具">
	<div class="p-6 md:p-8 border-b border-white/10">
		<div class="flex items-center gap-2 mb-6">
			<Icon name="material-symbols:build-circle-rounded" class="text-[var(--primary)] w-7 h-7" />
			<h1 class="text-2xl font-bold text-75">工具</h1>
		</div>
		<p class="text-sm text-50 mb-8 leading-relaxed">
			本站提供的实用工具入口，点击即可跳转使用。
		</p>

		<div class="space-y-0">
			{tools.map((t) => (
				<a
					href={t.href}
					class="group block p-5 hover:bg-white/5 transition-all border-b border-white/10 last:border-b-0"
				>
					<div class="flex items-center gap-3 mb-1">
						{t.isCustom ? (
							<img src={t.icon} alt="" class="w-6 h-6 text-[var(--primary)]" style="filter: brightness(0) saturate(100%) invert(56%) sepia(89%) saturate(2476%) hue-rotate(191deg) brightness(101%) contrast(101%);" />
						) : (
							<Icon name={t.icon} class="w-6 h-6 text-[var(--primary)]" />
						)}
						<span class="text-lg font-bold text-75 group-hover:text-[var(--primary)] transition">{t.title}</span>
					</div>
					<p class="text-sm text-50 ml-9">{t.desc}</p>
				</a>
			))}
		</div>
	</div>
</MainGridLayout>

---
// 零宽短链接解码跳转页面
// 捕获所有 /s/* 路径（包括带零宽字符的路径）

// 需要提供一个默认的静态路径用于生成 index.html
export function getStaticPaths() {
	return [
		{ params: { code: undefined } }
	];
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>短链接跳转</title>
	<style>
		body {
			font-family: system-ui, -apple-system, sans-serif;
			background: var(--card-bg, #f5f5f5);
			color: var(--text-75, #333);
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			margin: 0;
		}
		.container {
			text-align: center;
			padding: 2rem;
			border-radius: 1rem;
			background: var(--card-bg, white);
			box-shadow: 0 2px 12px rgba(0,0,0,0.08);
			max-width: 480px;
		}
		.spinner {
			width: 48px;
			height: 48px;
			border: 4px solid var(--primary, #10b981);
			border-top-color: transparent;
			border-radius: 50%;
			animation: spin 1s linear infinite;
			margin-bottom: 1.5rem;
		}
		@keyframes spin {
			to { transform: rotate(360deg); }
		}
		.error {
			color: #ef4444;
		}
		.target-url {
			margin-top: 1rem;
			padding: 0.75rem;
			background: rgba(0,0,0,0.05);
			border-radius: 0.5rem;
			word-break: break-all;
			font-size: 0.875rem;
		}
		.manual-link {
			display: inline-block;
			margin-top: 1.5rem;
			padding: 0.75rem 1.5rem;
			background: var(--primary, #10b981);
			color: white;
			border-radius: 0.5rem;
			text-decoration: none;
			font-weight: 500;
		}
		.manual-link:hover {
			opacity: 0.9;
		}
	</style>
</head>
<body>
	<div class="container">
		<div class="spinner" id="spinner"></div>
		<p id="status">正在解析短链接...</p>
		<div id="error-container" style="display:none;">
			<p class="error" id="error-message"></p>
			<div class="target-url" id="decoded-url" style="display:none;"></div>
			<a href="#" id="manual-jump" class="manual-link" style="display:none;">手动跳转</a>
		</div>
	</div>

	<script>
		// 零宽字符字母表：ZWSP=0, ZWNJ=1
		const ZW_CHARS = ['\u200B', '\u200C'];

		/**
		 * 解码零宽字符编码的 URL
		 * @param {string} encoded - 零宽字符序列
		 * @returns {string|null} - 解码后的 URL，失败返回 null
		 */
		function decodeUrl(encoded) {
			try {
				// 1. 提取零宽字符序列
				const zwSequence = encoded.split('').filter(c => ZW_CHARS.includes(c));

				if (zwSequence.length === 0) {
					return null;
				}

				// 2. 转为二进制字符串
				let binary = '';
				for (const c of zwSequence) {
					binary += ZW_CHARS.indexOf(c).toString();
				}

				// 3. 二进制 → 字节数组
				const bytes = [];
				for (let i = 0; i < binary.length; i += 8) {
					const byteStr = binary.slice(i, i + 8);
					if (byteStr.length === 8) {
						bytes.push(parseInt(byteStr, 2));
					}
				}

				// 4. UTF-8 解码
				const decoder = new TextDecoder();
				return decoder.decode(new Uint8Array(bytes));
			} catch (e) {
				console.error('解码失败:', e);
				return null;
			}
		}

		/**
		 * 显示错误状态
		 * @param {string} message - 错误信息
		 * @param {string|null} decodedUrl - 解码得到的 URL（如果有）
		 */
		function showError(message, decodedUrl = null) {
			const spinner = document.getElementById('spinner');
			const status = document.getElementById('status');
			const errorContainer = document.getElementById('error-container');
			const errorMessage = document.getElementById('error-message');
			const decodedUrlEl = document.getElementById('decoded-url');
			const manualJump = document.getElementById('manual-jump');

			spinner.style.display = 'none';
			status.style.display = 'none';
			errorContainer.style.display = 'block';
			errorMessage.textContent = message;

			if (decodedUrl) {
				decodedUrlEl.style.display = 'block';
				decodedUrlEl.textContent = decodedUrl;
				manualJump.style.display = 'inline-block';
				manualJump.href = decodedUrl;
			}
		}

		// 主执行逻辑
		function main() {
			// 获取路径（去掉 /s/ 前缀）
			const pathname = window.location.pathname;
			const encodedPart = pathname.replace(/^\/s\//, '');

			// 如果没有编码部分，跳转到生成器页面
			if (!encodedPart || encodedPart.length === 0) {
				window.location.href = '/s/';
				return;
			}

			// 检查是否包含零宽字符
			const hasZwChars = ZW_CHARS.some(c => encodedPart.includes(c));

			if (!hasZwChars) {
				showError('无效的短链接格式：未检测到零宽字符编码。');
				return;
			}

			// 解码 URL
			const targetUrl = decodeUrl(encodedPart);

			if (!targetUrl) {
				showError('解码失败：无法从路径中提取有效链接。');
				return;
			}

			// 验证 URL 格式
			try {
				new URL(targetUrl);
			} catch (e) {
				showError('解码得到的 URL 格式无效。', targetUrl);
				return;
			}

			// 自动跳转
			window.location.href = targetUrl;
		}

		// 页面加载后执行
		document.addEventListener('DOMContentLoaded', main);
	</script>
</body>
</html>